# Required for Groq (Llama 3.3 70B)
PLATFORM_GROQ_API_KEY=your_groq_api_key_here

# Optional: extra Groq keys for rotation
# PLATFORM_GROQ_API_KEY_2=
# PLATFORM_GROQ_API_KEY_3=

# Optional: fallback to OpenAI
# PLATFORM_OPENAI_API_KEY=

# Optional: orchestrator providers (same names as core.config / orchestrator)
# PLATFORM_GEMINI_API_KEY=
# PLATFORM_OPENROUTER_API_KEY=
