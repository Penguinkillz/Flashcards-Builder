{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install \"git+https://${GITHUB_USERNAME}:${GITHUB_TOKEN}@github.com/Penguinkillz/Orchestrator.git@main\" && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "python -m uvicorn main:app --host 0.0.0.0 --port $PORT"
  }
}
